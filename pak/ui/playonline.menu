	// Column header tabs and highlight columns

#define COLUMN_HEIGHT		194
#define SERVERNAME_WIDTH	236
#define MAPNAME_WIDTH		96
#define PLAYERS_WIDTH		42
#define GAMETYPE_WIDTH		48
#define PING_WIDTH			34
#define SETTINGS_WIDTH		98
#define FAVORITE_WIDTH		12

	// --- Server Name column ---
	itemDef {
		name		"serverColumnTab"
		group		"grpTabs"
		rect		12 182 $evalfloat(SERVERNAME_WIDTH+1) 16
		type		ITEM_TYPE_BUTTON
		text		"SERVER NAME"
		textfont	UI_FONT_ARIBLK_27
		textscale	.19
		textalignx	4
		textaligny	12
		style		WINDOW_STYLE_FILLED
		backcolor	0.10 0.10 0.12 .40
		forecolor	0.55 0.55 0.60 1
		border		WINDOW_BORDER_FULL
		bordercolor	0.22 0.22 0.25 .30
		visible		1
		tooltip		"Click here to sort by Server Name"

		action {
			setitemcolor "grpColumns" backcolor 0 0 0 0 ;
			setitemcolor "grpTabs" backcolor .10 .10 .12 .40 ;
			setitemcolor "grpTabs" forecolor .55 .55 .60 1 ;
			setitemcolor "serverColumn" backcolor .14 .16 .20 .25 ;
			setitemcolor "serverColumnTab" backcolor .18 .20 .26 .50 ;
			setitemcolor "serverColumnTab" forecolor .92 .92 .95 1 ;
			uiScript ServerSort 0
		}
	}

	itemDef {
		name		"serverColumn"
		group		"grpColumns"
		rect		12 197 $evalfloat(SERVERNAME_WIDTH+1) COLUMN_HEIGHT
		style		WINDOW_STYLE_FILLED
		backcolor	0 0 0 0
		border		WINDOW_BORDER_FULL
		bordercolor	0.22 0.22 0.25 .20
		visible		1
		decoration
	}

	// --- Map Name column ---
	itemDef {
		name		"mapColumnTab"
		group		"grpTabs"
		rect		$evalfloat(12+SERVERNAME_WIDTH) 182 $evalfloat(MAPNAME_WIDTH+1) 16
		type		ITEM_TYPE_BUTTON
		text		"MAP NAME"
		textfont	UI_FONT_ARIBLK_27
		textscale	.19
		textalignx	4
		textaligny	12
		style		WINDOW_STYLE_FILLED
		backcolor	0.10 0.10 0.12 .40
		forecolor	0.55 0.55 0.60 1
		border		WINDOW_BORDER_FULL
		bordercolor	0.22 0.22 0.25 .30
		visible		1
		tooltip		"Click here to sort by Campaign or Map name"

		action {
			setitemcolor "grpColumns" backcolor 0 0 0 0 ;
			setitemcolor "grpTabs" backcolor .10 .10 .12 .40 ;
			setitemcolor "grpTabs" forecolor .55 .55 .60 1 ;
			setitemcolor "mapColumn" backcolor .14 .16 .20 .25 ;
			setitemcolor "mapColumnTab" backcolor .18 .20 .26 .50 ;
			setitemcolor "mapColumnTab" forecolor .92 .92 .95 1 ;
			uiScript ServerSort 1
		}
	}

	itemDef {
		name		"mapColumn"
		group		"grpColumns"
		rect		$evalfloat(12+SERVERNAME_WIDTH) 197 $evalfloat(MAPNAME_WIDTH+1) COLUMN_HEIGHT
		style		WINDOW_STYLE_FILLED
		backcolor	0 0 0 0
		border		WINDOW_BORDER_FULL
		bordercolor	0.22 0.22 0.25 .20
		visible		1
		decoration
	}

