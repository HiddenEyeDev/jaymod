#include "ui/menudef.h"

// Defines //

#define WINDOW_X		16
#define WINDOW_Y		16
#define WINDOW_WIDTH	608
#define WINDOW_HEIGHT	448
#define GROUP_NAME		"grpPlayOnline"

// Macros //

#include "ui/menumacros.h"

// Play Online Menu //

menuDef {
	name		"playonline"
	visible		0
	fullscreen	0
	rect		WINDOW_X WINDOW_Y WINDOW_WIDTH WINDOW_HEIGHT
	style		WINDOW_STYLE_FILLED

	onOpen {
		conditionalScript cl_punkbuster 0
			( "hide bttn_pbenable ; show bttn_pbdisable" )
			( "show bttn_pbenable ; hide bttn_pbdisable" )

		// sort by servername ?
		conditionalScript serversort_0 2
			( "setitemcolor grpColumns backcolor 0 0 0 0 ; setitemcolor grpTabs backcolor .10 .10 .12 .40 ; setitemcolor grpTabs forecolor .55 .55 .60 1 ; setitemcolor serverColumn backcolor .14 .16 .20 .25 ; setitemcolor serverColumnTab backcolor .18 .20 .26 .50 ; setitemcolor serverColumnTab forecolor .92 .92 .95 1" )
			( "clearFocus" )

		// sort by mapname ?
		conditionalScript serversort_1 2
			( "setitemcolor grpColumns backcolor 0 0 0 0 ; setitemcolor grpTabs backcolor .10 .10 .12 .40 ; setitemcolor grpTabs forecolor .55 .55 .60 1 ; setitemcolor mapColumn backcolor .14 .16 .20 .25 ; setitemcolor mapColumnTab backcolor .18 .20 .26 .50 ; setitemcolor mapColumnTab forecolor .92 .92 .95 1" )
			( "clearFocus" )

		// sort by playercount ?
		conditionalScript serversort_2 2
			( "setitemcolor grpColumns backcolor 0 0 0 0 ; setitemcolor grpTabs backcolor .10 .10 .12 .40 ; setitemcolor grpTabs forecolor .55 .55 .60 1 ; setitemcolor playerColumn backcolor .14 .16 .20 .25 ; setitemcolor playerColumnTab backcolor .18 .20 .26 .50 ; setitemcolor playerColumnTab forecolor .92 .92 .95 1" )
			( "clearFocus" )

		// sort by gametype ?
		conditionalScript serversort_3 2
			( "setitemcolor grpColumns backcolor 0 0 0 0 ; setitemcolor grpTabs backcolor .10 .10 .12 .40 ; setitemcolor grpTabs forecolor .55 .55 .60 1 ; setitemcolor gametypeColumn backcolor .14 .16 .20 .25 ; setitemcolor gametypeColumnTab backcolor .18 .20 .26 .50 ; setitemcolor gametypeColumnTab forecolor .92 .92 .95 1" )
			( "clearFocus" )

		// sort by ping ?
		conditionalScript serversort_4 2
			( "setitemcolor grpColumns backcolor 0 0 0 0 ; setitemcolor grpTabs backcolor .10 .10 .12 .40 ; setitemcolor grpTabs forecolor .55 .55 .60 1 ; setitemcolor pingColumn backcolor .14 .16 .20 .25 ; setitemcolor pingColumnTab backcolor .18 .20 .26 .50 ; setitemcolor pingColumnTab forecolor .92 .92 .95 1" )
			( "clearFocus" )

		clearCvar ui_filterdescription
	}

	onESC {
		uiScript closeJoin ;
		close playonline ;
		open main
	}

// Window //

	WINDOW( "PLAY ONLINE", 146 )

// Subwindows //

#define SUBWINDOW_WIDTH		WINDOW_WIDTH-12

// Message of the Day //

	#define FILTERS_WIDTH		.75*(WINDOW_WIDTH-18)

	SUBWINDOW( 6, 34, (FILTERS_WIDTH), 28, "MESSAGE OF THE DAY" )
	itemDef {
		name			"messageOfTheDay"
		group			GROUP_NAME
		rect			8 50 $evalfloat((FILTERS_WIDTH)-4) 10
		ownerDraw		UI_SERVERMOTD
		textfont		UI_FONT_COURBD_21
		textstyle		ITEM_TEXTSTYLE_SHADOWED
		textscale		.2
		textalignx		4
		textaligny		8
		forecolor		0.55 0.55 0.60 1
		visible			1
		decoration
	}

// Filters //

	SUBWINDOW( 6, 66, (FILTERS_WIDTH), 94, "FILTERS" )

	MULTIACTIONLEFT( 8, 82, .5*((FILTERS_WIDTH)-6), 10, "Source:", .2, 8, "ui_netSource", cvarFloatList { "Local" 0 "Internet" 1 "Favorites" 2 }, uiScript UpdateFilter, "Choose the type of game servers to display from Internet, local and the favorites list" )
	MULTIACTIONLEFT( 8+.5*((FILTERS_WIDTH)-6)+2, 82, .5*((FILTERS_WIDTH)-6), 10, "Game Type:", .2, 8, "ui_joinGameType", cvarFloatList { "All" -1 "Objective" 2 "Stopwatch" 3 "Campaign" 4 "Last Man Standing" 5 }, uiScript RefreshFilter, "Displays only game servers offering this Game Type" )

	itemDef {
		name		"filtericonEmptyFull"
		rect		10 94 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_emptyfull"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 10+12, 94, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowEmptyOrFull", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Empty and Full Servers", "Includes or excludes empty and full servers from the server list" )

	itemDef {
		name		"filtericonPassword"
		rect		10 106 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_pass"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 10+12, 106, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowPasswordProtected", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Password Protected Servers", "Includes or excludes password protected servers from the server list" )

	itemDef {
		name		"filtericonFriendlyFire"
		rect		10 118 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_ff"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 10+12, 118, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowFriendlyFire", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Servers with Friendly Fire", "Includes or excludes servers where team mates can damage each other from the server list" )

	itemDef {
		name		"filtericonMaxLives"
		rect		10 130 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_lives"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 10+12, 130, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowMaxlives", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Servers with Max Lives", "Includes or excludes servers that limit the number of player lives per match from the server list" )

	itemDef {
		name		"filtericonWeapRestrict"
		rect		$evalfloat(8+.5*((FILTERS_WIDTH)-6)+2+2) 94 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_weap"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 8+.5*((FILTERS_WIDTH)-6)+2+2+12, 94, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowWeaponsRestricted", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Servers with Weapon Restrictions", "Includes or excludes servers that limit the number of available heavy weapons from the server list" )

	itemDef {
		name		"filtericonPunkBuster"
		rect		$evalfloat(8+.5*((FILTERS_WIDTH)-6)+2+2) 106 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_pb"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 8+.5*((FILTERS_WIDTH)-6)+2+2+12, 106, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowPunkBuster", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting PunkBuster Servers", "Includes or excludes Punk Buster servers from the server list" )

	itemDef {
		name		"filtericonAntilag"
		rect		$evalfloat(8+.5*((FILTERS_WIDTH)-6)+2+2) 118 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_antilag"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 8+.5*((FILTERS_WIDTH)-6)+2+2+12, 118, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowAntilag", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Anti-Lag Servers", "Includes or excludes servers with support for modem players from the server list" )

	itemDef {
		name		"filtericonTeamBalance"
		rect		$evalfloat(8+.5*((FILTERS_WIDTH)-6)+2+2) 130 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/filter_balance"
		forecolor	0.55 0.60 0.70 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 8+.5*((FILTERS_WIDTH)-6)+2+2+12, 130, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowTeamBalanced", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting Servers with Force Team Balance", "Includes or excludes servers that enforce balanced teams from the server list" )

	itemDef {
		name		"filtericonJaymodOnly"
		rect		10 142 10 10
		style		WINDOW_STYLE_SHADER
		background	"ui/assets/icon_jaymod"
		forecolor	0.45 0.65 0.95 1
		visible		1
		decoration
	}
	TRICHECKBOXACTIONMULTI( 10+12, 142, .5*((FILTERS_WIDTH)-6)-14, 10, .2, 8, "ui_browserShowJaymodOnly", cvarFloatList { "Filter Disabled" 0 "Only show..." 1 "Don't show..." 2 }, uiScript RefreshFilter ; setcvar ui_filterdescription "Filter affecting servers running Jaymod", "Includes or excludes servers that run Jaymod" )

// Map Preview //

	SUBWINDOW( 6+(FILTERS_WIDTH)+4, 34, ((SUBWINDOW_WIDTH)-(FILTERS_WIDTH)-4), 126, "PREVIEW" )
	itemDef {
		name		"mapPreview"
		group		GROUP_NAME
		rect		$evalfloat(6+(FILTERS_WIDTH)+4+2) $evalfloat(34+16) $evalfloat((SUBWINDOW_WIDTH)-(FILTERS_WIDTH)-4-4) $evalfloat(.75*((SUBWINDOW_WIDTH)-(FILTERS_WIDTH)-4-4))
		style		WINDOW_STYLE_FILLED
		ownerdraw	UI_NETMAPPREVIEW
		backcolor	0.04 0.04 0.05 .70
		border		WINDOW_BORDER_FULL
		bordercolor	0.22 0.22 0.25 .30
		visible		1
		decoration
	}

// Server Browser //

	SUBWINDOW( 6, 164, (SUBWINDOW_WIDTH), 256, "SERVER BROWSER" )

